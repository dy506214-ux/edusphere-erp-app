generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String              @id @default(uuid())
  email                 String              @unique
  password              String
  username              String?             @unique
  firstName             String
  lastName              String
  phone                 String?
  avatar                String?
  dateOfBirth           DateTime?
  gender                Gender?
  bloodGroup            String?
  address               String?
  role                  UserRole
  roles                 UserRole[]
  isActive              Boolean             @default(true)
  emailVerified         Boolean             @default(false)
  lastLogin             DateTime?
  lastPasswordChange    DateTime            @default(now())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  qrCode                String?
  qrIssued              Boolean             @default(false)
  qrIssuedAt            DateTime?
  leaveBalances         LeaveBalance[]
  payrolls              Payroll[]           @relation("PayrollEmployee")
  performanceReviews    PerformanceReview[] @relation("RevieweeRelation")
  conductedReviews      PerformanceReview[] @relation("ReviewerRelation")
  salaryStructure       SalaryStructure?
  calendarEventsCreated SchoolCalendar[]    @relation("CalendarCreatedBy")
  serviceRequests       ServiceRequest[]    @relation("RequesterRelation")
  reviewedRequests      ServiceRequest[]    @relation("ReviewerRelation")
  staff                 Staff?
  student               Student?
  teacher               Teacher?

  @@index([email])
  @@index([role])
}

model Student {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  admissionNumber       String                 @unique
  rollNumber            String?
  joiningDate           DateTime               @default(now())
  currentClassId        String?
  sectionId             String?
  academicYearId        String
  admissionType         AdmissionType          @default(NEW)
  medium                Medium                 @default(ENGLISH)
  previousSchool        String?
  previousClass         String?
  tcNumber              String?
  tcIssueDate           DateTime?
  leavingReason         String?
  religion              String?
  caste                 String?
  nationality           String?
  permanentAddress      String?
  city                  String?
  state                 String?
  pincode               String?
  emergencyContact      String?
  emergencyPhone        String?
  medicalConditions     String?
  allergies             String?
  status                StudentStatus          @default(ACTIVE)
  leavingDate           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  latitude              Float?
  longitude             Float?
  assignmentSubmissions AssignmentSubmission[]
  attendance            AttendanceRecord[]
  examResults           ExamResult[]
  feeAdjustments        FeeAdjustment[]
  feePayments           FeePayment[]
  libraryIssues         LibraryIssue[]
  libraryReservations   LibraryReservation[]
  rfidCard              RFIDCard?
  reportCards           ReportCard[]
  academicYear          AcademicYear           @relation(fields: [academicYearId], references: [id])
  currentClass          Class?                 @relation(fields: [currentClassId], references: [id])
  section               Section?               @relation(fields: [sectionId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents             StudentDocument[]
  feeLedgers            StudentFeeLedger[]
  parents               StudentParent[]
  transportAllocation   TransportAllocation?

  @@index([admissionNumber])
  @@index([currentClassId])
  @@index([status])
}

model StudentParent {
  id           String             @id @default(uuid())
  studentId    String
  parentId     String
  relationship ParentRelationship
  parent       Parent             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
}

model Parent {
  id            String          @id @default(uuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?         @unique
  occupation    String?
  qualification String?
  annualIncome  Float?
  aadhaar       String?
  pan           String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  students      StudentParent[]

  @@index([email])
}

model StudentDocument {
  id           String   @id @default(uuid())
  studentId    String
  documentType String
  documentName String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedAt   DateTime @default(now())
  uploadedBy   String?
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Teacher {
  id                  String               @id @default(uuid())
  userId              String               @unique
  employeeId          String               @unique
  joiningDate         DateTime
  qualification       String
  experience          Int?
  specialization      String?
  assignedScannerId   String?
  status              EmployeeStatus       @default(ACTIVE)
  leavingDate         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assignments         Assignment[]
  attendance          AttendanceRecord[]
  assignedClass       Class?
  examInvigilators    ExamInvigilator[]
  libraryReservations LibraryReservation[]
  rfidCard            RFIDCard?
  subjects            SubjectTeacher[]
  assignedScanner     QRScanner?           @relation("TeacherScanner", fields: [assignedScannerId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableSlots      TimetableSlot[]

  @@index([employeeId])
  @@index([userId])
}

model Staff {
  id                String             @id @default(uuid())
  userId            String             @unique
  employeeId        String             @unique
  joiningDate       DateTime
  designation       String
  department        String?
  status            EmployeeStatus     @default(ACTIVE)
  leavingDate       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assignedScannerId String?
  attendance        AttendanceRecord[]
  rfidCard          RFIDCard?
  assignedScanner   QRScanner?         @relation("StaffScanner", fields: [assignedScannerId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAttendant Vehicle[]          @relation("Attendant")
  managedVehicles   Vehicle?           @relation("PrimaryDriver")
  vehicleChecklists VehicleChecklist[]

  @@index([employeeId])
}

model AcademicYear {
  id               String             @id @default(uuid())
  name             String             @unique
  startDate        DateTime
  endDate          DateTime
  isCurrent        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  classes          Class[]
  enquiries        Enquiry[]
  exams            Exam[]
  feePayments      FeePayment[]
  feeStructures    FeeStructure[]
  leaveBalances    LeaveBalance[]
  students         Student[]
  feeLedgers       StudentFeeLedger[]
  terms            Term[]
  timetableConfigs TimetableConfig[]

  @@index([isCurrent])
}

model Class {
  id               String           @id @default(uuid())
  name             String
  numericValue     Int
  description      String?
  academicYearId   String
  classTeacherId   String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignments      Assignment[]
  attendanceSlots  AttendanceSlot[]
  academicYear     AcademicYear     @relation(fields: [academicYearId], references: [id])
  classTeacher     Teacher?         @relation(fields: [classTeacherId], references: [id])
  enquiries        Enquiry[]
  exams            Exam[]
  feeStructures    FeeStructure[]
  sections         Section[]
  students         Student[]
  subjects         Subject[]
  timetables       Timetable[]
  timetableConfigs TimetableConfig?

  @@unique([name, academicYearId])
  @@index([academicYearId])
}

model Section {
  id              String           @id @default(uuid())
  name            String
  classId         String
  maxStudents     Int              @default(40)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     Assignment[]
  attendanceSlots AttendanceSlot[]
  class           Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  students        Student[]
  timetableSlots  TimetableSlot[]

  @@unique([classId, name])
  @@index([classId])
}

model Subject {
  id                String             @id @default(uuid())
  name              String
  code              String             @unique
  description       String?
  classId           String
  type              SubjectType        @default(CORE)
  totalMarks        Int                @default(100)
  passMarks         Int                @default(40)
  credits           Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assignments       Assignment[]
  attendanceRecords AttendanceRecord[]
  attendanceSlots   AttendanceSlot[]
  examSubjects      ExamSubject[]
  class             Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  teachers          SubjectTeacher[]
  timetableSlots    TimetableSlot[]

  @@index([classId])
  @@index([code])
}

model SubjectTeacher {
  id         String   @id @default(uuid())
  subjectId  String
  teacherId  String
  assignedAt DateTime @default(now())
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([subjectId, teacherId])
  @@index([subjectId])
  @@index([teacherId])
}

model Timetable {
  id            String          @id @default(uuid())
  name          String
  type          TimetableType   @default(DAILY)
  pdfUrl        String?
  classId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  class         Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  slots         TimetableSlot[]

  @@index([classId])
  @@index([isActive])
}

model TimetableConfig {
  id                 String       @id @default(uuid())
  classId            String       @unique
  academicYearId     String
  startTime          String
  endTime            String
  periodDuration     Int          @default(40)
  lunchStartTime     String?
  lunchDuration      Int?
  shortBreakTime     String?
  shortBreakDuration Int?
  daysActive         Int[]        @default([1, 2, 3, 4, 5, 6])
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id])
  class              Class        @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model Room {
  id        String          @id @default(uuid())
  name      String          @unique
  capacity  Int?
  building  String?
  type      RoomType        @default(CLASSROOM)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  slots     TimetableSlot[]

  @@index([type])
}

model TimetableSlot {
  id              String    @id @default(uuid())
  timetableId     String
  dayOfWeek       Int
  startTime       String
  endTime         String
  period          Int
  sectionId       String
  subjectId       String?
  teacherId       String?
  durationMinutes Int       @default(40)
  isSpecialSlot   Boolean   @default(false)
  roomId          String?
  specialSlotName String?
  room            Room?     @relation(fields: [roomId], references: [id])
  section         Section   @relation(fields: [sectionId], references: [id])
  subject         Subject?  @relation(fields: [subjectId], references: [id])
  teacher         Teacher?  @relation(fields: [teacherId], references: [id])
  timetable       Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@index([timetableId])
  @@index([sectionId])
  @@index([teacherId])
  @@index([roomId])
}

model RFIDCard {
  id         String         @id @default(uuid())
  cardNumber String         @unique
  holderType RFIDHolderType
  studentId  String?        @unique
  teacherId  String?        @unique
  staffId    String?        @unique
  isActive   Boolean        @default(true)
  issuedDate DateTime       @default(now())
  expiryDate DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  staff      Staff?         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student    Student?       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher?       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([cardNumber])
  @@index([holderType])
}

model QRScanner {
  id                String             @id @default(uuid())
  name              String
  location          String?
  scannerType       ScannerType        @default(ENTRY)
  latitude          Float?
  longitude         Float?
  geofenceRadius    Int                @default(10)
  allowedRoles      UserRole[]
  isActive          Boolean            @default(true)
  createdBy         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  assignedStaffs    Staff[]            @relation("StaffScanner")
  assignedTeachers  Teacher[]          @relation("TeacherScanner")

  @@index([isActive])
  @@index([scannerType])
}

model AttendanceSlot {
  id           String             @id @default(uuid())
  date         DateTime           @db.Date
  attendeeType AttendeeType       @default(STUDENT)
  classId      String?
  sectionId    String?
  createdBy    String
  status       SlotStatus         @default(OPEN)
  closedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  subjectId    String?
  records      AttendanceRecord[]
  class        Class?             @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?           @relation(fields: [sectionId], references: [id])
  subject      Subject?           @relation(fields: [subjectId], references: [id])

  @@unique([date, attendeeType, classId, sectionId, subjectId])
  @@index([createdBy, date])
  @@index([classId, date])
  @@index([subjectId])
}

model AttendanceRecord {
  id            String           @id @default(uuid())
  attendeeType  AttendeeType
  studentId     String?
  teacherId     String?
  staffId       String?
  date          DateTime         @db.Date
  checkInTime   DateTime?
  checkOutTime  DateTime?
  status        AttendanceStatus
  scannedByRFID Boolean          @default(false)
  deviceId      String?
  scannedByQR   Boolean          @default(false)
  scannerId     String?
  scanLatitude  Float?
  scanLongitude Float?
  geofenceValid Boolean?
  slotId        String?
  markedBy      String?
  remarks       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subjectId     String?
  scanner       QRScanner?       @relation(fields: [scannerId], references: [id])
  slot          AttendanceSlot?  @relation(fields: [slotId], references: [id])
  staff         Staff?           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student       Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject?         @relation(fields: [subjectId], references: [id])
  teacher       Teacher?         @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
  @@index([teacherId, date])
  @@index([staffId, date])
  @@index([date])
  @@index([slotId])
  @@index([status])
}

model Term {
  id             String       @id @default(uuid())
  name           String
  termType       TermType
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  weightage      Float        @default(100)
  order          Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  exams          Exam[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([name, academicYearId])
  @@index([academicYearId])
}

model GradeScale {
  id        String            @id @default(uuid())
  name      String            @unique
  scaleType GradeScaleType
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())
  exams     Exam[]
  entries   GradeScaleEntry[]
}

model GradeScaleEntry {
  id           String     @id @default(uuid())
  gradeScaleId String
  grade        String
  minPercent   Float
  maxPercent   Float
  gradePoint   Float?
  description  String?
  order        Int
  gradeScale   GradeScale @relation(fields: [gradeScaleId], references: [id], onDelete: Cascade)

  @@index([gradeScaleId])
}

model Exam {
  id             String        @id @default(uuid())
  name           String
  description    String?
  examType       ExamType
  status         ExamStatus    @default(DRAFT)
  classId        String
  academicYearId String
  termId         String?
  gradeScaleId   String?
  startDate      DateTime
  endDate        DateTime
  isFrozen       Boolean       @default(false)
  frozenAt       DateTime?
  frozenBy       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  gradeScale     GradeScale?   @relation(fields: [gradeScaleId], references: [id])
  term           Term?         @relation(fields: [termId], references: [id])
  examResults    ExamResult[]
  examSubjects   ExamSubject[]
  reportCards    ReportCard[]

  @@index([classId])
  @@index([academicYearId])
  @@index([termId])
}

model ExamSubject {
  id                String            @id @default(uuid())
  examId            String
  subjectId         String
  examDate          DateTime
  startTime         String
  duration          Int
  totalMarks        Int
  passMarks         Int
  theoryMaxMarks    Float             @default(0)
  practicalMaxMarks Float             @default(0)
  internalMaxMarks  Float             @default(0)
  invigilators      ExamInvigilator[]
  exam              Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject           Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, subjectId])
  @@index([examId])
  @@index([subjectId])
}

model ExamInvigilator {
  id            String      @id @default(uuid())
  examSubjectId String
  teacherId     String
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  teacher       Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, teacherId])
  @@index([examSubjectId])
  @@index([teacherId])
}

model ExamResult {
  id            String           @id @default(uuid())
  examId        String
  studentId     String
  totalMarks    Float
  obtainedMarks Float
  percentage    Float
  grade         String?
  rank          Int?
  result        ExamResultStatus
  remarks       String?
  isPublished   Boolean          @default(false)
  publishedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  marks         ExamMark[]
  exam          Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model ExamMark {
  id                String       @id @default(uuid())
  examResultId      String
  subjectName       String
  subjectCode       String
  totalMarks        Float
  obtainedMarks     Float
  grade             String?
  theoryObtained    Float        @default(0)
  practicalObtained Float        @default(0)
  internalObtained  Float        @default(0)
  isAbsent          Boolean      @default(false)
  absenceType       AbsenceType?
  enteredBy         String?
  enteredAt         DateTime?
  examResult        ExamResult   @relation(fields: [examResultId], references: [id], onDelete: Cascade)

  @@index([examResultId])
}

model ReportCard {
  id              String           @id @default(uuid())
  examId          String
  studentId       String
  generatedBy     String
  status          ReportCardStatus @default(DRAFT)
  submittedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionRemark String?
  pdfUrl          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  exam            Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model ReportTemplate {
  id                String   @id @default(uuid())
  name              String   @unique
  showAttendance    Boolean  @default(true)
  showRemarks       Boolean  @default(true)
  showRank          Boolean  @default(false)
  schoolLogo        String?
  signedByTeacher   Boolean  @default(true)
  signedByPrincipal Boolean  @default(true)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FeeStructure {
  id                   String             @id @default(uuid())
  name                 String
  description          String?
  classId              String?
  academicYearId       String
  totalAmount          Float
  frequency            FeeFrequency
  dueDay               Int                @default(10)
  earlyPaymentDiscount Float?             @default(0)
  latePaymentPenalty   Float?             @default(0)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  payments             FeePayment[]
  academicYear         AcademicYear       @relation(fields: [academicYearId], references: [id])
  class                Class?             @relation(fields: [classId], references: [id])
  items                FeeStructureItem[]
  ledgers              StudentFeeLedger[]

  @@index([classId])
  @@index([academicYearId])
}

model FeeStructureItem {
  id             String       @id @default(uuid())
  feeStructureId String
  headName       FeeHeadType
  amount         Float
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
}

model StudentFeeLedger {
  id             String          @id @default(uuid())
  studentId      String
  academicYearId String
  feeStructureId String
  totalPayable   Float
  totalPaid      Float           @default(0)
  totalPending   Float
  totalDiscount  Float           @default(0)
  status         FeeLedgerStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  adjustments    FeeAdjustment[]
  payments       FeePayment[]
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  feeStructure   FeeStructure    @relation(fields: [feeStructureId], references: [id])
  student        Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, feeStructureId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([status])
}

model FeeAdjustment {
  id          String            @id @default(uuid())
  studentId   String
  ledgerId    String
  type        FeeAdjustmentType
  amount      Float
  reason      String
  status      AdjustmentStatus  @default(PENDING)
  requestedBy String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ledger      StudentFeeLedger  @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([ledgerId])
  @@index([status])
}

model FeePayment {
  id                String           @id @default(uuid())
  receiptNumber     String           @unique
  studentId         String
  feeStructureId    String
  ledgerId          String
  academicYearId    String
  amount            Float
  discount          Float            @default(0)
  penalty           Float            @default(0)
  totalAmount       Float
  paymentType       FeePaymentType   @default(RECEIPT)
  paymentDate       DateTime         @default(now())
  paymentMode       PaymentMode
  transactionId     String?
  bankName          String?
  chequeNumber      String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  forMonth          Int?
  forYear           Int?
  status            PaymentStatus    @default(COMPLETED)
  receiptUrl        String?
  collectedBy       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  academicYear      AcademicYear     @relation(fields: [academicYearId], references: [id])
  feeStructure      FeeStructure     @relation(fields: [feeStructureId], references: [id])
  ledger            StudentFeeLedger @relation(fields: [ledgerId], references: [id])
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([receiptNumber])
  @@index([paymentDate])
  @@index([ledgerId])
  @@index([academicYearId])
}

model Assignment {
  id          String                 @id @default(uuid())
  title       String
  description String?
  filePath    String?
  dueDate     DateTime
  subjectId   String
  classId     String
  sectionId   String?
  teacherId   String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  class       Class                  @relation(fields: [classId], references: [id])
  section     Section?               @relation(fields: [sectionId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  teacher     Teacher                @relation(fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]

  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  filePath     String?
  status       AssignmentStatus @default(PENDING)
  grade        String?
  feedback     String?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Book {
  id              String               @id @default(uuid())
  title           String
  author          String
  isbn            String?              @unique
  publisher       String?
  publishedYear   Int?
  edition         String?
  category        String
  subCategory     String?
  language        String               @default("English")
  type            BookType             @default(PHYSICAL)
  condition       BookCondition        @default(NEW)
  status          BookStatus           @default(AVAILABLE)
  totalCopies     Int                  @default(1)
  availableCopies Int                  @default(1)
  shelfLocation   String?
  price           Float?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  issues          LibraryIssue[]
  reservations    LibraryReservation[]

  @@index([isbn])
  @@index([category])
  @@index([title])
  @@index([status])
}

model LibraryIssue {
  id                String      @id @default(uuid())
  bookId            String
  studentId         String
  issueDate         DateTime    @default(now())
  dueDate           DateTime
  returnDate        DateTime?
  renewalCount      Int         @default(0)
  status            IssueStatus @default(ISSUED)
  fineAmount        Float       @default(0)
  finePaid          Boolean     @default(false)
  conditionOnReturn String?
  issuedBy          String?
  returnedBy        String?
  remarks           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  book              Book        @relation(fields: [bookId], references: [id])
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

model LibraryReservation {
  id              String            @id @default(uuid())
  bookId          String
  studentId       String?
  teacherId       String?
  reservationDate DateTime          @default(now())
  expiryDate      DateTime?
  status          ReservationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  book            Book              @relation(fields: [bookId], references: [id])
  student         Student?          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher         Teacher?          @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([studentId])
  @@index([status])
}

model InventoryItem {
  id            String          @id @default(uuid())
  name          String
  description   String?
  category      String
  itemCode      String          @unique
  quantity      Int             @default(0)
  unit          String
  minStockLevel Int             @default(0)
  unitPrice     Float?
  location      String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  movements     StockMovement[]

  @@index([itemCode])
  @@index([category])
}

model StockMovement {
  id               String        @id @default(uuid())
  itemId           String
  movementType     MovementType
  quantity         Int
  referenceNumber  String?
  description      String?
  previousQuantity Int
  newQuantity      Int
  performedBy      String?
  createdAt        DateTime      @default(now())
  item             InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@index([movementType])
  @@index([createdAt])
}

model Announcement {
  id             String               @id @default(uuid())
  title          String
  content        String
  targetAudience String[]
  classIds       String[]
  priority       AnnouncementPriority @default(NORMAL)
  isPublished    Boolean              @default(false)
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdBy      String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([isPublished])
  @@index([createdAt])
  @@index([targetAudience])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  title      String
  message    String
  type       NotificationType
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model SchoolConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model ServiceRequest {
  id              String               @id @default(uuid())
  requestNumber   String               @unique
  requesterId     String
  type            ServiceRequestType
  subject         String
  description     String
  startDate       DateTime?
  endDate         DateTime?
  attachmentUrl   String?
  status          ServiceRequestStatus @default(PENDING)
  priority        RequestPriority      @default(NORMAL)
  reviewerId      String?
  reviewerRemarks String?
  reviewedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  metadata        String?
  requester       User                 @relation("RequesterRelation", fields: [requesterId], references: [id])
  reviewer        User?                @relation("ReviewerRelation", fields: [reviewerId], references: [id])

  @@index([requesterId])
  @@index([status])
  @@index([type])
}

model SalaryStructure {
  id            String    @id @default(uuid())
  employeeId    String    @unique
  basicSalary   Float
  allowances    Float     @default(0)
  deductions    Float     @default(0)
  grossSalary   Float
  effectiveFrom DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payrolls      Payroll[]
  employee      User      @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id          String          @id @default(uuid())
  structureId String
  employeeId  String
  month       Int
  year        Int
  presentDays Int             @default(0)
  absentDays  Int             @default(0)
  basicSalary Float
  allowances  Float
  deductions  Float
  netSalary   Float
  status      PayrollStatus   @default(PENDING)
  paidAt      DateTime?
  paidBy      String?
  remarks     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  employee    User            @relation("PayrollEmployee", fields: [employeeId], references: [id])
  structure   SalaryStructure @relation(fields: [structureId], references: [id])

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
}

model LeaveBalance {
  id             String       @id @default(uuid())
  employeeId     String
  leaveType      LeaveType
  total          Float
  used           Float        @default(0)
  pending        Float        @default(0)
  academicYearId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  employee       User         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveType, academicYearId])
}

model PerformanceReview {
  id           String       @id @default(uuid())
  employeeId   String
  reviewerId   String
  reviewDate   DateTime     @default(now())
  periodStart  DateTime
  periodEnd    DateTime
  ratings      Json
  strengths    String?
  improvements String?
  comments     String?
  status       ReviewStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  employee     User         @relation("RevieweeRelation", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer     User         @relation("ReviewerRelation", fields: [reviewerId], references: [id])

  @@index([employeeId])
}

model SchoolBranding {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id                 String            @id @default(uuid())
  studentName        String
  parentName         String
  phone              String
  email              String?
  classId            String
  academicYearId     String
  source             EnquirySource     @default(WALK_IN)
  status             EnquiryStatus     @default(PENDING)
  isConverted        Boolean           @default(false)
  convertedAt        DateTime?
  convertedStudentId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  academicYear       AcademicYear      @relation(fields: [academicYearId], references: [id])
  class              Class             @relation(fields: [classId], references: [id])
  followUps          EnquiryFollowUp[]

  @@index([status])
  @@index([classId])
  @@index([academicYearId])
}

model EnquiryFollowUp {
  id               String    @id @default(uuid())
  enquiryId        String
  staffId          String
  remark           String
  nextFollowUpDate DateTime?
  createdAt        DateTime  @default(now())
  enquiry          Enquiry   @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([enquiryId])
}

model Vehicle {
  id                 String               @id @default(uuid())
  registrationNumber String               @unique
  name               String
  make               String
  model              String
  year               Int
  color              String?
  chassisNumber      String?              @unique
  engineNumber       String?              @unique
  fuelType           FuelType             @default(DIESEL)
  capacity           Int
  ownershipType      OwnershipType        @default(SCHOOL_OWNED)
  registrationDate   DateTime?
  registrationExpiry DateTime?
  insurancePolicy    String?
  insuranceExpiry    DateTime?
  fitnessExpiry      DateTime?
  permitExpiry       DateTime?
  pucExpiry          DateTime?
  odometerReading    Float                @default(0)
  status             VehicleStatus        @default(ACTIVE)
  driverId           String?              @unique
  attendantId        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  alerts             TransportAlert[]
  trips              TransportTrip[]
  attendant          Staff?               @relation("Attendant", fields: [attendantId], references: [id])
  primaryDriver      Staff?               @relation("PrimaryDriver", fields: [driverId], references: [id])
  dailyChecklists    VehicleChecklist[]
  fuelLogs           VehicleFuelLog[]
  maintenanceLogs    VehicleMaintenance[]
}

model TransportRoute {
  id            String                @id @default(uuid())
  name          String                @unique
  colorCode     String                @default("#FFD700")
  startLocation String?
  endLocation   String?
  totalDistance Float?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  stops         RouteStop[]
  allocations   TransportAllocation[]
  trips         TransportTrip[]
}

model RouteStop {
  id          String                @id @default(uuid())
  routeId     String
  name        String
  latitude    Float
  longitude   Float
  arrivalTime String
  order       Int
  radius      Int                   @default(100)
  createdAt   DateTime              @default(now())
  route       TransportRoute        @relation(fields: [routeId], references: [id], onDelete: Cascade)
  allocations TransportAllocation[]
}

model TransportAllocation {
  id             String           @id @default(uuid())
  studentId      String           @unique
  routeId        String
  stopId         String
  academicYearId String?
  status         AllocationStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  route          TransportRoute   @relation(fields: [routeId], references: [id])
  stop           RouteStop        @relation(fields: [stopId], references: [id])
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([stopId])
}

model TransportTrip {
  id              String            @id @default(uuid())
  routeId         String
  vehicleId       String
  type            TripType
  status          TripStatus        @default(SCHEDULED)
  actualStartTime DateTime?
  actualEndTime   DateTime?
  createdAt       DateTime          @default(now())
  alerts          TransportAlert[]
  route           TransportRoute    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])
  locationLogs    VehicleLocation[]
}

model VehicleLocation {
  id        String        @id @default(uuid())
  tripId    String
  latitude  Float
  longitude Float
  speed     Float?
  timestamp DateTime      @default(now())
  trip      TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, timestamp])
}

model TransportAlert {
  id        String        @id @default(uuid())
  tripId    String
  type      AlertType
  message   String
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())
  latitude  Float?
  longitude Float?
  severity  AlertSeverity @default(MEDIUM)
  vehicleId String
  trip      TransportTrip @relation(fields: [tripId], references: [id])
  vehicle   Vehicle       @relation(fields: [vehicleId], references: [id])

  @@index([tripId])
  @@index([vehicleId])
  @@index([type])
}

model VehicleMaintenance {
  id              String    @id @default(uuid())
  vehicleId       String
  serviceDate     DateTime
  serviceType     String
  odometerReading Float
  cost            Float
  vendorName      String?
  description     String?
  nextServiceDue  DateTime?
  invoiceUrl      String?
  createdAt       DateTime  @default(now())
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleFuelLog {
  id              String   @id @default(uuid())
  vehicleId       String
  date            DateTime
  quantity        Float
  amount          Float
  odometerReading Float
  stationName     String?
  createdAt       DateTime @default(now())
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleChecklist {
  id                 String   @id @default(uuid())
  vehicleId          String
  driverId           String
  checkDate          DateTime @default(now())
  tiresOk            Boolean  @default(true)
  brakesOk           Boolean  @default(true)
  lightsOk           Boolean  @default(true)
  fuelLevelOk        Boolean  @default(true)
  cleanlinessOk      Boolean  @default(true)
  firstAidOk         Boolean  @default(true)
  fireExtinguisherOk Boolean  @default(true)
  remarks            String?
  createdAt          DateTime @default(now())
  driver             Staff    @relation(fields: [driverId], references: [id])
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model SchoolCalendar {
  id           String           @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  type         CalendarType     @default(EVENT)
  category     CalendarCategory @default(ACADEMIC)
  audience     CalendarAudience @default(ALL)
  isFullDay    Boolean          @default(true)
  startTime    DateTime?
  endTime      DateTime?
  location     String?
  isWorkingDay Boolean          @default(true)
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    User             @relation("CalendarCreatedBy", fields: [createdById], references: [id])

  @@index([date])
  @@index([type])
  @@index([category])
}

