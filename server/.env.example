# ── server/.env.example ──────────────────────────────────────────────────────
# Documentation for required environment variables for the EduSphere API

# ── Primary Server Config ──────────────────────────────────────────────
PORT=5001
NODE_ENV=production
# JWT_SECRET: Strong random string for signing tokens
JWT_SECRET=your_jwt_secret_here
# COOKIE_SECRET: For signing cookies
COOKIE_SECRET=your_cookie_secret_here

# ── Database (PostgreSQL) ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://johndoe:mypassword@localhost:5432/edusphere

# ── Redis (Cache) ───────────────────────────────────────────────────────
# Required for session storage or certain performance optimizations
REDIS_URL=redis://localhost:6379

# ── Security & CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (the frontend Render URL)
ALLOWED_ORIGINS=https://edusphere-client.onrender.com

# (Optional) Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Cloudinary (File Storage) ──────────────────────────────────────────
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── School Identity ────────────────────────────────────────────────────
SCHOOL_ID=EDU001
SCHOOL_NAME=EduSphere Academy

# ── Feature Flags & Config ─────────────────────────────────────────────
FEE_CURRENCY=INR
SCHOOL_START_TIME=08:30
LIBRARY_FINE_PER_DAY=5
MAX_BOOKS_PER_STUDENT=3
PASSING_PERCENTAGE=40
